@page "/login"
@using Blazored.LocalStorage
@using CineVibeClient.Models

<h3>Login</h3>

@if (loginErrorMessage != null)
{
    <div class="alert alert-danger">@loginErrorMessage</div>
}

<EditForm Model="loginModel" OnValidSubmit="HandleLogin">
    <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <InputText id="username" class="form-control" @bind-Value="loginModel.Username" />
    </div>
    <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <InputText id="password" class="form-control" type="password" @bind-Value="loginModel.Password" />
    </div>
    <button type="submit" class="btn btn-primary">Login</button>
</EditForm>

<div class="mt-3">
    <button @onclick="NavigateToAdminLogin" class="btn btn-outline-primary">Are you an Admin?</button>
</div>

@code {
    private LoginModel loginModel = new();
    private string? loginErrorMessage;

    [Inject]
    private IHttpClientFactory ClientFactory { get; set; } = null!;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = null!;

    [Inject]
    private ILocalStorageService LocalStorage { get; set; } = null!;

    private async Task HandleLogin()
    {
        var JavaAPI = ClientFactory.CreateClient("JavaAPI");
        try
        {
            var response = await JavaAPI.PostAsJsonAsync("api/customers/login", loginModel);
            if (response.IsSuccessStatusCode)
            {
                var user = await response.Content.ReadFromJsonAsync<Customer>();
                if (user != null)
                {
                    await LocalStorage.SetItemAsync("user", user);
                    await LocalStorage.SetItemAsync("userType", "Customer");
                    NavigationManager.NavigateTo("/myaccount", forceLoad: true);
                }
            }
            else
            {
                loginErrorMessage = "Invalid username or password.";
            }
        }
        catch (Exception ex)
        {
            loginErrorMessage = $"An error occurred: {ex.Message}";
        }
    }

    private void NavigateToAdminLogin()
    {
        NavigationManager.NavigateTo("/admin-login");
    }

    private class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
