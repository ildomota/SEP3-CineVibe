@page "/movies"

<h3>Movie List</h3>

@if (movies == null)
{
    <p>Loading...</p>
}
else
{
    <div class="movie-grid">
        @foreach (var movie in movies)
        {
            <div class="movie-box">
                <img src="@($"{NavigationManager.BaseUri}{movie.PosterURL?.TrimStart('/')}" )" 
                     alt="@movie.Title" 
                     style="width: 250px; height: 200px; object-fit: cover; padding-left: 16%" />
                <div class="movie-footer">
                    <div class="movie-title">@movie.Title</div>
                    <div class="movie-date">@movie.ReleaseDate.ToShortDateString()</div>
                    <button class="movie-button" @onclick="() => NavigateToDetails(movie.movieid)">More Info</button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Movie>? movies;

    protected override async Task OnInitializedAsync()
    {
        if (Http == null)
        {
            Console.WriteLine("HttpClient is null. Check the dependency injection in Program.cs.");
            return;
        }

        try
        {
            Console.WriteLine("Fetching movies from API...");
            movies = await Http.GetFromJsonAsync<List<Movie>>("api/movie");

            if (movies != null && movies.Count > 0)
            {
                Console.WriteLine($"Movies fetched successfully. Count: {movies.Count}");
            }
            else
            {
                Console.WriteLine("No movies were fetched or the list is empty.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching movies: {ex.Message}");
        }
    }

    [Inject]
    private HttpClient? Http { get; set; }

    [Inject]
    private NavigationManager NavigationManager { get; set; } = null!;

    private void NavigateToDetails(int movieId)
    {
        NavigationManager.NavigateTo($"/moviedetails/{movieId}");
    }
}