@page "/booksnacks/{BookingId:int}"
@using CineVibeClient.Models
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<h3>Select Your Snacks</h3>

@if (snacks == null)
{
    <p>Loading snacks...</p>
}
else
{
    <!-- Sezione Snacks -->
    <h4>Snacks</h4>
    <div class="row row-cols-1 row-cols-md-5 g-4">
        @foreach (var snack in snacks.Where(s => IsSnack(s.Name)))
        {
            <div class="col">
                <div class="card text-center h-100">
                    <img src="@($"http://localhost:5169/{snack.ImagePath}")"
                         class="card-img-top"
                         alt="@snack.Name"
                         style="height: 150px; object-fit: contain;" />
                    <div class="card-body">
                        <h5>@snack.Name</h5>
                        <p>Price: €@snack.Price</p>
                        @for (int i = 1; i <= 3; i++)
                        {
                            int quantity = i; // Capture the loop variable
                            <button class="btn btn-outline-primary me-1" @onclick="() => SelectSnack(snack, quantity)">
                                @quantity
                            </button>
                        }

                        <button class="btn btn-danger" @onclick="() => RemoveSnack(snack.SnackId)">x</button>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Sezione Bevande -->
    <h4>Drinks</h4>
    <div class="row row-cols-1 row-cols-md-5 g-4">
        @foreach (var drink in snacks.Where(s => IsDrink(s.Name)))
        {
            <div class="col">
                <div class="card text-center h-100">
                    <img src="@($"http://localhost:5169/{drink.ImagePath}")"
                         class="card-img-top"
                         alt="@drink.Name"
                         style="height: 150px; object-fit: contain;" />
                    <div class="card-body">
                        <h5>@drink.Name</h5>
                        <p>Price: €@drink.Price</p>
                        @for (int i = 1; i <= 3; i++)
                        {
                            int quantity = i; // Capture the loop variable
                            <button class="btn btn-outline-primary me-1" @onclick="() => SelectSnack(drink, quantity)">
                                @quantity
                            </button>
                        }

                        <button class="btn btn-danger" @onclick="() => RemoveSnack(drink.SnackId)">x</button>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Sezione Ordine Finale -->
    @if (selectedSnacks.Any())
    {
        <h4>Your Order</h4>
        <div class="row row-cols-1 g-3">
            @foreach (var item in selectedSnacks)
            {
                <div class="col">
                    <div class="card shadow-sm border-0 h-100"style="background-color: #f8f9fa; border-radius: 8px;">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title">@item.Name</h5>
                                <p class="card-text mb-1"><strong>Quantity:</strong> @item.Quantity</p>
                                <p class="card-text mb-1"><strong>Total:</strong> €@(item.Quantity * item.Price)</p>
                            </div>
                            <button class="btn btn-danger btn-sm" @onclick="() => RemoveSnack(item.SnackId)">Remove</button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Totale Ordine -->
        <div class="card shadow-sm mt-3 border-0" style="background-color: #f8f9fa; padding: 15px; border-radius: 8px;">
            <div class="d-flex flex-column">
                <p class="h5 mb-3"><strong>Total Price:</strong> €@TotalPrice</p>
                <div class="d-flex align-items-center">
                    <label class="me-2 mb-0"><strong>Loyalty Points to Use:</strong></label>
                    <input type="number" min="0" step="5" @bind="loyaltyPointsToUse" 
                           @oninput="ValidateLoyaltyPoints" max="@userLoyaltyPoints"
                           style="width: 60px;" />
                    <button class="btn btn-success btn-sm ms-2" @onclick="ApplyLoyaltyPoints">Apply</button>
                </div>
                <p class="h5 mt-3"><strong>Discounted Total:</strong> €@DiscountedTotal</p>
            </div>
        </div>
        
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success mt-3">
                @successMessage
            </div>
        }

        <p><strong>Discounted Total:</strong> €@DiscountedTotal</p>

        <button class="btn btn-primary" @onclick="ConfirmOrder">Confirm Order</button>
    }
}

@code {
    [Parameter]
    public int BookingId { get; set; }

    private List<Snacks> snacks = new();
    private List<SelectedSnack> selectedSnacks = new();
    private int loyaltyPointsToUse = 0;
    private int userLoyaltyPoints = 0;
    private decimal TotalPrice => selectedSnacks.Sum(s => s.Quantity * s.Price);
    private decimal DiscountedTotal => TotalPrice - (loyaltyPointsToUse / 5);
    private string successMessage = string.Empty;


    protected override async Task OnInitializedAsync()
    {
        snacks = await Http.GetFromJsonAsync<List<Snacks>>("api/snacks") ?? new List<Snacks>();
        var user = await LocalStorage.GetItemAsync<Customer>("user");
        userLoyaltyPoints = user?.LoyaltyPoints ?? 0;
    }

    private bool IsSnack(string name) => name switch
    {
        "Popcorn" or "Hot Dog" or "Nachos" or "Bag of Candies" or "Bretzel" => true,
        _ => false
    };

    private bool IsDrink(string name) => name switch
    {
        "Water" or "Coca Cola" or "Fanta" or "Sprite" or "Beer" => true,
        _ => false
    };

    private void SelectSnack(Snacks snack, int quantity)
    {
        var existing = selectedSnacks.FirstOrDefault(s => s.SnackId == snack.SnackId);
        if (existing != null)
        {
            existing.Quantity = quantity;
        }
        else
        {
            selectedSnacks.Add(new SelectedSnack
            {
                SnackId = snack.SnackId,
                Name = snack.Name,
                Price = snack.Price,
                Quantity = quantity
            });
        }

        StateHasChanged();
    }

    private void RemoveSnack(int snackId)
    {
        selectedSnacks.RemoveAll(s => s.SnackId == snackId);
    }

    private async Task ApplyLoyaltyPoints()
    {
        if (loyaltyPointsToUse <= 0 || loyaltyPointsToUse > userLoyaltyPoints)
        {
            Console.WriteLine("Invalid points to use.");
            return;
        }

        var user = await LocalStorage.GetItemAsync<Customer>("user");
        if (user == null) return;

        try
        {
            var response = await Http.PutAsJsonAsync($"api/customer/loyaltypoints/{user.CustomerId}", loyaltyPointsToUse);

            if (response.IsSuccessStatusCode)
            {
                user.LoyaltyPoints -= loyaltyPointsToUse; // Update points locally
                await LocalStorage.SetItemAsync("user", user); // Update local storage
                successMessage = "Your points have been deducted and your discount is now applied!";
                Console.WriteLine("Loyalty points applied successfully.");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                successMessage = $"Failed to apply points: {error}";
            }
        }
        catch (Exception ex)
        {
            successMessage = $"Error: {ex.Message}";
        }

        StateHasChanged(); // Refresh the UI
    }


    private void ValidateLoyaltyPoints(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int points))
        {
            loyaltyPointsToUse = Math.Min(points, userLoyaltyPoints);
        }
        else
        {
            loyaltyPointsToUse = 0;
        }
    }

    private async Task ConfirmOrder()
    {
        var user = await LocalStorage.GetItemAsync<Customer>("user");
        if (user == null)
        {
            Console.WriteLine("User not found in LocalStorage.");
            return;
        }

        // Prepara i dati dell'ordine
        var snackOrders = selectedSnacks.Select(s => new SnackOrder
        {
            CustomerId = user.CustomerId,
            SnackId = s.SnackId,
            Quantity = s.Quantity,
            TotalPrice = s.Price, // Singolo prezzo per snack
            BookingId = BookingId,
            OrderDate = DateTime.Now
        }).ToList();

        try
        {
            var response = await Http.PostAsJsonAsync("api/snackorder", snackOrders);

            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine("Order confirmed successfully!");
                NavigationManager.NavigateTo("/mysnackorders");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Failed to place the order: {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }



    private class SelectedSnack
    {
        public int SnackId { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public int Quantity { get; set; }
    }
}