@page "/register"
@using CineVibeClient.Models
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager

<h3>Register</h3>

@if (registerMessage != null)
{
    <div class="alert alert-info">@registerMessage</div>
}

<EditForm Model="registerModel" OnValidSubmit="RegisterUser">
    <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <InputText id="username" class="form-control" @bind-Value="registerModel.Username" />
    </div>
    <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <InputText id="password" class="form-control" type="password" @bind-Value="registerModel.Password" />
    </div>
    <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <InputText id="email" class="form-control" @bind-Value="registerModel.Email" />
    </div>
    <button type="submit" class="btn btn-success">Register</button>
</EditForm>

<div class="mt-3">
    <button class="btn btn-outline-info" @onclick="GoToAdminRegister">Are you an Admin?</button>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? registerMessage;

    private async Task RegisterUser()
    {
        var JavaAPI = ClientFactory.CreateClient("JavaAPI");
        var registerData = new
        {
            registerModel.Username,
            passwordHash = registerModel.Password, // Plain text password; sarà hashata nel backend Java
            registerModel.Email,
            status = "Active"
        };

        try
        {
            var response = await JavaAPI.PostAsJsonAsync("api/customers/register", registerData);

            if (response.IsSuccessStatusCode)
            {
                registerMessage = "Registration successful!";
                registerModel = new(); // Resetta il form
            }
            else
            {
                registerMessage = "Registration failed. Try again.";
            }
        }
        catch (Exception ex)
        {
            registerMessage = $"An error occurred: {ex.Message}";
        }
    }

    private void GoToAdminRegister()
    {
        NavigationManager.NavigateTo("/register-admin");
    }

    private class RegisterModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
    }
}
